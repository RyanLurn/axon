{
  "name": "@repo/db",
  "type": "module",
  "private": "true",
  "scripts": {
    "build": "tsdown",
    "try": "bun run src/try.ts",
    "check-types": "tsc --noEmit",
    "lint": "eslint --cache",
    "generate": "bun --env-file=.env.local run drizzle-kit generate",
    "migrate": "bun --env-file=.env.local run drizzle-kit migrate"
  },
  "exports": {
    "./*": {
      "import": "./dist/*.mjs",
      "types": "./dist/*.d.mts"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@repo/core": "workspace:*",
    "@repo/randomizer": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "drizzle-orm": "^0.45.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsdown-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
